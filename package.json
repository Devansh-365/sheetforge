{
  "name": "acid-sheets",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "pnpm --filter @acid-sheets/web dev",
    "dev:all": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck"
  },
  "workspaces": [
    "apps/*",
    "slices/*",
    "packages/*",
    "shared/*"
  ],
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "@biomejs/biome": "^1.9.4",
    "eslint": "^9.17.0",
    "eslint-plugin-boundaries": "^5.0.1"
  }
}
