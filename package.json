{
  "name": "acid-sheets",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "turbo run dev --filter=@acid-sheets/web --filter=@acid-sheets/api",
    "dev:web": "pnpm --filter @acid-sheets/web dev",
    "dev:api": "pnpm --filter @acid-sheets/api dev",
    "db:push": "node --env-file=.env shared/db/scripts/push-migration.mjs",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "@biomejs/biome": "^1.9.4",
    "eslint": "^9.17.0",
    "eslint-plugin-boundaries": "^5.0.1"
  }
}
